{
	"name": "maxhandmade/mhm-currency-switcher",
	"description": "Multi-currency support for WooCommerce with real-time exchange rates and seamless checkout integration.",
	"type": "wordpress-plugin",
	"license": "GPL-3.0-or-later",
	"authors": [
		{
			"name": "MaxHandMade",
			"homepage": "https://maxhandmade.com"
		}
	],
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"wp-coding-standards/wpcs": "^3.2",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.1",
		"php-stubs/woocommerce-stubs": "^9.0",
		"php-stubs/wordpress-stubs": "^6.0",
		"phpstan/phpstan": "^1.10",
		"szepeviktor/phpstan-wordpress": "^1.3",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"MhmCurrencySwitcher\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"MhmCurrencySwitcher\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"lint": "phpcs --runtime-set ignore_warnings_on_exit 1",
		"lint:fix": "phpcbf",
		"analyze": "phpstan analyse"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	}
}
